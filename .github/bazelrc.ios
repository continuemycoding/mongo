# iOS 越狱机交叉编译参考配置（由 build-ios-mongod.sh 内联传入，wrapper 不支持 --bazelrc=）
#
# libmongocrypt 的 kms_crypto_apple.c 使用 macOS 专有 Security API（SecItemImport），
# iPhoneOS SDK 不提供，故关闭 SSL 走 none 加密后端。
# -target / -isysroot / -miphoneos-version-min 在 shell 中按当前 Xcode SDK 注入。
#
#   --//bazel/config:ssl=False
#   --//bazel/config:server_js=False
#   --//bazel/config:js_engine=none
#   --copt=-march=armv8-a+crc
#   --copt=-DXP_IOS=1
#   --linkopt=-march=armv8-a+crc
